<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Wedding Of Indah & Yani</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Pinyon+Script&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:#2b000f;
font-family:'Cinzel',serif;
overflow:hidden;
}

.cover{
height:100vh;
background:
linear-gradient(rgba(30,0,10,.55),rgba(30,0,10,.75)),
url("cover.jpg") center/cover;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
color:white;
}

.box{
background:rgba(80,0,20,.45);
padding:35px;
border:2px solid gold;
border-radius:20px;
backdrop-filter:blur(6px);
}

h3{
font-weight:400;
letter-spacing:3px;
}

h1{
font-size:60px;
font-family:'Pinyon Script',cursive;
color:#FFD700;
margin:20px 0;
}

h2{
font-size:42px;
color:white;
}

p{
margin-top:15px;
font-size:18px;
}

button{
margin-top:30px;
padding:15px 40px;
background:#800020;
color:white;
border:none;
border-radius:50px;
font-size:18px;
cursor:pointer;
transition:.4s;
}

button:hover{
background:gold;
color:#800020;
}
</style>
</head>

<body>

<div class="cover">

<div class="box">

<h3>THE WEDDING OF</h3>

<h2>Yani</h2>

<h1>&</h1>

<h2>Indah</h2>

<p>24 September 2026</p>

<button onclick="buka()">Buka Undangan</button>

</div>

</div>

<audio id="musik" autoplay loop>
<source src="lagu.mp3" type="audio/mpeg">
</audio>

<script>
function buka(){
document.body.style.overflow="auto";
alert("Selamat datang di Undangan Pernikahan Indah & Yani ❤️");
}
</script>

</body>
</html>
